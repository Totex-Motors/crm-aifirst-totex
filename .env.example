# Supabase (OBRIGATORIO)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL do app (nao alterar pra dev local)
VITE_APP_URL=http://localhost:8080

# Feature flags (opcional)
VITE_COCKPIT_V2=true
